# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/digital_office
POSTGRES_PASSWORD=change-me-in-production

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI (Gemini — free tier at aistudio.google.com) ────────
GEMINI_API_KEY=AIza...

# ── Meta (Facebook + Instagram) ───────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_ACCOUNT_ID=

# ── OpenClaw.ai ───────────────────────────────────────────
OPENCLAW_API_KEY=
OPENCLAW_WEBHOOK_SECRET=

# ── API ───────────────────────────────────────────────────
API_PORT=3001
API_SECRET_KEY=change-me-in-production

# ── Dashboard ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Public URLs (used by Docker on VPS) ───────────────────
PUBLIC_API_URL=https://your-domain.com/api
PUBLIC_WS_URL=wss://your-domain.com
# VPS public IP or domain — used by docker-compose to build the browser WS URL
HOST=your-vps-ip-or-domain

# ── X / Twitter (Phase 2 — not used yet) ─────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Canva (image generation) ─────────────────────────────
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://YOUR_VPS_IP:3001/api/v1/canva/callback
CANVA_LOGOS_FOLDER_ID=  # Folder ID of the "Approved Logos" folder in Canva
